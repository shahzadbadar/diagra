flowchart LR
  %% Clients
  Client[Web / Mobile / Partner Apps]

  %% Edge Layer
  APIGW[API Gateway]

  %% Compute Layer
  Lambda[Lambda]

  %% Event Layer
  EventBridge[EventBridge]
  SNS[SNS]

  %% Data Layer
  DynamoDB[DynamoDB]
  SQS[SQS Queue]
  DLQ[Dead Letter Queue]

  %% Consumers
  Consumer1[Downstream Service A]
  Consumer2[Downstream Service B]
  Email[Email / SMS / Webhook]

  %% Observability
  CloudWatch[CloudWatch]
  XRay[X-Ray]

  %% Main request flow
  Client -->|HTTPS Request| APIGW
  APIGW -->|Invoke| Lambda

  %% Processing flow
  Lambda -->|Read / Write| DynamoDB
  Lambda -->|Publish Event| EventBridge

  %% Event routing
  EventBridge -->|Route Event| SNS
  EventBridge -->|Async Job| SQS

  %% Notification fanout
  SNS -->|Notify| Email
  SNS -->|Trigger| Consumer1

  %% Queue processing
  SQS -->|Process| Consumer2
  SQS -->|Failed Retries| DLQ

  %% Monitoring (dashed)
  APIGW -.->|Logs / Metrics| CloudWatch
  Lambda -.->|Logs / Metrics| CloudWatch
  EventBridge -.->|Rule Metrics| CloudWatch
  SNS -.->|Delivery Metrics| CloudWatch
  SQS -.->|Queue Metrics| CloudWatch
  DLQ -.->|Failure Alerts| CloudWatch
  APIGW -.->|Trace| XRay
  Lambda -.->|Trace| XRay